# ── Backend (Railway env vars) ────────────────────────────────────────────────
# Railway injects PORT automatically — do not set this manually
# PORT=8000

# Database — use Railway's PostgreSQL plugin or keep SQLite for simple deploys
# Railway PostgreSQL (recommended): copy from Railway dashboard > Variables
DATABASE_URL=sqlite:////app/data/lens_inspections.db

# Model paths (relative to /app inside container)
MODEL_PATH=models/best.pt
LENS_SEG_MODEL_PATH=models/lens_seg.pt
SEG_MODEL_PATH=models/yolov8n-seg.pt

# Detection thresholds
CONFIDENCE_THRESHOLD=0.3
SEG_CONFIDENCE=0.35

# Pipeline timing (seconds)
SEG_INTERVAL=3.0
DB_WRITE_INTERVAL=5.0
WS_PING_INTERVAL=20.0

# ── Frontend (Vercel env vars) ────────────────────────────────────────────────
# Set this in Vercel dashboard > Project > Settings > Environment Variables
# Use wss:// for HTTPS Vercel deployments pointing to Railway
VITE_API_URL=https://your-backend.railway.app
